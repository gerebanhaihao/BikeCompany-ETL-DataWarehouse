      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// 如果title为空，则根据gender和marital_status进行填充
if (title == null || title == '') {
    if (gender == 'M') {
        new_title = 'Mr.';
    } else if (gender == 'F') {
        if (marital_status == 'M') {
            new_title = 'Mrs.';
        } else if (marital_status == 'S') {
            new_title = 'Miss.';
        } else if (marital_status == null || marital_status == '') {
            new_title = 'Ms.';
        } else {
            new_title = null; // 其他情况保留null
        }
    }
} else {
    // 如果title有值，则保留原来的title
    new_title = title;
}
</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>new_title</name>
        <rename>new_title</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
