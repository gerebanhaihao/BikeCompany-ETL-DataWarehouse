    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var product_category = null;

// 拼接 product_category 字段
if (product_category_name != null &amp;&amp; product_subcategory_name != null) {
    // 如果两个字段都不为空，用 ; 拼接
    product_category = product_category_name + ";" + product_subcategory_name;
} else if (product_category_name != null) {
    // 如果 product_category_name 不为空，使用它的值
    product_category = product_category_name;
} else if (product_subcategory_name != null) {
    // 如果 product_subcategory_name 不为空，使用它的值
    product_category = product_subcategory_name;
}

</jsScript_script>
